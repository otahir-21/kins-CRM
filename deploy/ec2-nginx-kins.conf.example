# Example: expose Node (PM2 on 127.0.0.1:3000) on port 80 so mobile/web can use
# http://YOUR_PUBLIC_IP/... without :3000 in the URL.
#
# On Ubuntu EC2:
#   sudo apt update && sudo apt install -y nginx
#   sudo cp deploy/ec2-nginx-kins.conf.example /etc/nginx/sites-available/kins
#   sudo ln -sf /etc/nginx/sites-available/kins /etc/nginx/sites-enabled/kins
#   sudo rm -f /etc/nginx/sites-enabled/default
#   sudo nginx -t && sudo systemctl reload nginx
# Security group: inbound TCP 80 from 0.0.0.0/0 (or restrict to your IPs).
#
# For HTTPS, use ACM + ALB in front of this instance, or certbot on a real domain
# (not shown here).

server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
        client_max_body_size 25m;
    }
}
