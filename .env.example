# Bunny CDN (for post media and onboarding uploads)
# Storage zone: kins-app | Hostname: uk.storage.bunnycdn.com | Pull zone: kins-app.b-cdn.net
BUNNY_STORAGE_ZONE=kins-app
BUNNY_ACCESS_KEY=your-bunny-access-key-here
BUNNY_CDN_URL=https://kins-app.b-cdn.net
BUNNY_STORAGE_REGION=uk

# MongoDB (user profile + interests - no Firestore)
# Local: mongodb://localhost:27017/kindash
# Atlas: mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/DATABASE?retryWrites=true&w=majority&appName=Kins
MONGODB_URI=mongodb://localhost:27017/kindash

# Firebase-only: skip Mongo connection (set false even if MONGODB_URI is left in .env from a template)
# USE_MONGO=false

# Server Configuration
PORT=3000
NODE_ENV=development

# For scripts/tests pointing at deployed API (e.g. EC2)
# BASE_URL=http://16.16.96.232

# API Security (optional)
API_KEY=your-api-key-here

# Twilio Verify (phone auth - replaces Firebase Phone Auth)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# JWT (issued after successful OTP verification)
JWT_SECRET=your-secret-min-32-chars-for-production
JWT_EXPIRES_IN=7d

# Data backend selectors (migration flags)
# Default remains mongo. Set DATA_BACKEND_AUTH=firebase to enable Firebase auth data provider.
DATA_BACKEND_DEFAULT=mongo
DATA_BACKEND_AUTH=mongo
DATA_BACKEND_ME=mongo
DATA_BACKEND_FEED=mongo
DATA_BACKEND_INTERESTS=mongo
DATA_BACKEND_USERS=mongo
DATA_BACKEND_GROUPS=mongo
DATA_BACKEND_ADS=mongo
DATA_BACKEND_MARKETPLACE=mongo
DATA_BACKEND_SURVEYS=mongo
DATA_BACKEND_ONBOARDING=mongo
DATA_BACKEND_MODERATION=mongo
DATA_BACKEND_POSTS=mongo
DATA_BACKEND_VERIFICATION=mongo
DATA_BACKEND_NOTIFICATIONS=mongo

# Firebase (for group chat: custom token so Flutter can use Firestore + Storage)
# Project: kivi-b6393 — use same project in app (GoogleService-Info.plist / google-services.json)
# From Firebase Console: Project settings > Service accounts > Generate new private key (for kivi-b6393)
FIREBASE_PROJECT_ID=kivi-b6393
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@kivi-b6393.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
